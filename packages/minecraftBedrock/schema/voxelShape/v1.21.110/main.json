{
    "$schema": "http://json-schema.org/draft-07/schema",
    "type": "object",
    "properties": {
        "minecraft:voxel_shape": {
            "title": "Voxel Shape Definition",
            "type": "object",
            "properties": {
                "description": {
                    "title": "Description",
                    "$ref": "./description.json"
                },
                "shape": {
                    "type": "object",
                    "properties": {
                        "boxes": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "min": {
                                        "type": "array",
                                        "items": {
                                            "type": "number"
                                        },
                                        "minItems": 3,
                                        "maxItems": 3
                                    },
                                    "max": {
                                        "type": "array",
                                        "items": {
                                            "type": "number"
                                        },
                                        "minItems": 3,
                                        "maxItems": 3
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}