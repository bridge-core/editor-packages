{
    "$schema": "http://json-schema.org/draft-07/schema",
    "additionalProperties": false,
    "title": "Timer Flag 1",
    "description": "Fires an event when this behavior starts, then waits for a duration before stopping.",
    "type": "object",
    "properties": {
        "priority": {
            "$ref": "../../general/v1.16.0/behaviorPriority.json"
        },
        "cooldown_range": {
            "title": "Cooldown Range",
            "description": "Goal cooldown range in seconds.",
            "type": "object",
            "properties": {
                "min": {
                    "title": "Minimum",
                    "type": "number"
                },
                "max": {
                    "title": "Maximum",
                    "type": "number"
                }
            }
        },
        "duration_range": {
            "title": "Duration Range",
            "description": "Goal duration range in seconds.",
            "type": "object",
            "properties": {
                "min": {
                    "title": "Minimum",
                    "type": "number"
                },
                "max": {
                    "title": "Maximum",
                    "type": "number"
                }
            }
        },
        "on_start": {
            "title": "Event: On Start",
            "$ref": "../../general/v1.16.0/eventDefinition.json"
        },
        "on_end": {
            "title": "Event: On End",
            "$ref": "../../general/v1.16.0/eventDefinition.json"
        }
    }
}