{
    "$schema": "https://json-schema.org/draft-07/schema",
    "title": "Multi Block",
    "description": "",
    "type": "object",
    "properties": {
        "enabled_states": {
            "title": "Enabled States",
            "type": "array",
            "items": {
                "type": "string",
                "enum": [
                    "minecraft:multi_block_part"
                ]
            }
        },
        "parts": {
            "title": "Parts",
            "type": "integer",
            "minimum": 2,
            "maximum": 4
        },
        "direction": {
            "title": "Direction",
            "type": "string",
            "enum": [
                "up",
                "down"
            ]
        }
    },
    "additionalProperties": false
}